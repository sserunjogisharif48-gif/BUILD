<Window x:Class="ScholasticaReader.Views.ActivationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Scholastica Reader - Activation" Height="380" Width="500"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Scholastica Reader Activation" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" Grid.Row="0"/>
        <TextBlock Text="Your Hardware ID:" Grid.Row="1" Margin="0,5"/>
        <TextBox x:Name="HwidTextBox" IsReadOnly="True" Background="LightGray" Margin="0,5,0,15" Grid.Row="2"/>
        <TextBlock Text="Enter Activation Code:" Grid.Row="3" Margin="0,5"/>
        <TextBox x:Name="CodeTextBox" Margin="0,5,0,15" Grid.Row="4"/>
        <TextBlock x:Name="StatusText" Foreground="Red" Grid.Row="5" Margin="0,5"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="6" Margin="0,20,0,0">
            <Button x:Name="ActivateButton" Content="Activate" Width="100" Margin="0,0,10,0" Click="ActivateButton_Click"/>
            <Button x:Name="ExitButton" Content="Exit" Width="100" Click="ExitButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
