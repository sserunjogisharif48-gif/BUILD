<Window x:Class="ScholasticaReader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Scholastica Reader" Height="720" Width="1280"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <!-- Top menu -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="File">
                <MenuItem Header="Open Book" Click="OpenBook_Click"/>
                <Separator/>
                <MenuItem Header="Exit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="View">
                <MenuItem Header="Library" Click="Library_Click"/>
                <MenuItem Header="Notes" Click="Notes_Click"/>
            </MenuItem>
            <MenuItem Header="Help">
                <MenuItem Header="About" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <!-- Three-pane layout -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Library -->
            <Border Grid.Column="0" Background="#F0F0F0" BorderBrush="#CCC" BorderThickness="0,0,1,0">
                <ListBox x:Name="LibraryListBox" Margin="5">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Margin="3"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- Center: Book View (placeholder) -->
            <Border Grid.Column="1" Background="White">
                <WebBrowser x:Name="BookViewer" />
                <!-- or use WebView2 for EPUB -->
            </Border>

            <!-- Right: Annotation Panel -->
            <Border Grid.Column="2" Background="#FAFAFA" BorderBrush="#CCC" BorderThickness="1,0,0,0">
                <StackPanel Margin="10">
                    <TextBlock Text="Annotations" FontWeight="Bold" Margin="0,0,0,10"/>
                    <Button Content="Highlight" Margin="0,5"/>
                    <Button Content="Add Note" Margin="0,5"/>
                    <ListBox x:Name="NotesListBox" Height="300" Margin="0,10"/>
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window> 
